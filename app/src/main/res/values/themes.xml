<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Base.Theme.NavetteCampus" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/info</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/primary</item>
    </style>
    <style name="Theme.NavetteCampus.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#E5484D</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="windowSplashScreenAnimationDuration">600</item>
        <item name="postSplashScreenTheme">@style/Theme.NavetteCampus</item>
    </style>

    <style name="Theme.NavetteCampus" parent="Base.Theme.NavetteCampus" />
</resources>