<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background">

    <!-- Top section -->
    <LinearLayout
        android:id="@+id/layoutTop"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_alignParentTop="true"
        android:paddingTop="72dp"
        android:paddingBottom="24dp">

        <!-- Lottie bus animation -->
        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/lottieView"
            android:layout_width="180dp"
            android:layout_height="180dp"
            app:lottie_rawRes="@raw/bus_animation"
            app:lottie_autoPlay="true"
            app:lottie_loop="true" />

        <!-- App name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:letterSpacing="0.05"
            android:layout_marginTop="12dp" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ENS Marrakech"
            android:textSize="14sp"
            android:textColor="#CCFFFFFF"
            android:letterSpacing="0.1"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- Bottom card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/bottomCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        app:cardCornerRadius="32dp"
        app:cardElevation="24dp"
        app:cardBackgroundColor="?attr/colorSurface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp">

            <!-- Welcome title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bienvenue"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Choisissez votre profil pour continuer"
                android:textSize="13sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginBottom="28dp" />

            <!-- Student button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStudent"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="@string/btn_student"
                android:textSize="15sp"
                android:layout_marginBottom="12dp"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_student"
                app:iconSize="22dp"
                app:iconGravity="textStart"
                app:iconPadding="12dp" />

            <!-- Driver button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDriver"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="@string/btn_driver"
                android:textSize="15sp"
                android:layout_marginBottom="28dp"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_driver"
                app:iconSize="22dp"
                app:iconGravity="textStart"
                app:iconPadding="12dp"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/colorOutline"
                android:layout_marginBottom="20dp" />

            <!-- Theme toggle row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="?attr/selectableItemBackground"
                android:padding="4dp">

                <!-- Moon icon -->
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_moon"
                    app:tint="?attr/colorOnSurface"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Mode sombre"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurface" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchTheme"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</RelativeLayout>